
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the LinkFlow AI application, storing their preferences, LinkedIn connection details, and AI API configurations.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "name": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "linkedinId": {
          "type": "string",
          "description": "The unique identifier for the user's personal LinkedIn profile."
        },
        "linkedinAccessToken": {
          "type": "string",
          "description": "Encrypted access token."
        },
        "aiProvider": {
          "type": "string",
          "description": "The chosen AI model provider (e.g., 'gemini', 'openai')."
        },
        "postingTime": {
          "type": "string",
          "description": "Daily time for automated posts."
        },
        "automationEnabled": {
          "type": "boolean",
          "description": "Flag for daily automated posting."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "automationEnabled"
      ]
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Represents a LinkedIn post.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "hashtags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": ["draft", "scheduled", "posted", "failed"]
        },
        "linkedinPostUrn": {
          "type": "string",
          "description": "The URN returned by LinkedIn API, required for analytics."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "content",
        "status",
        "createdAt"
      ]
    },
    "PostAnalytics": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PostAnalytics",
      "type": "object",
      "description": "Stores performance metrics for a specific LinkedIn post.",
      "properties": {
        "id": {
          "type": "string"
        },
        "postId": {
          "type": "string"
        },
        "impressions": {
          "type": "number"
        },
        "likes": {
          "type": "number"
        },
        "comments": {
          "type": "number"
        },
        "shares": {
          "type": "number"
        },
        "engagementRate": {
          "type": "number"
        },
        "collectedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "postId",
        "impressions",
        "likes",
        "comments",
        "shares",
        "collectedAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "User profiles and settings."
        }
      },
      {
        "path": "/users/{userId}/posts/{postId}",
        "definition": {
          "schema": {
            "$ref": "#/backend/entities/Post"
          },
          "description": "User's LinkedIn posts."
        }
      },
      {
        "path": "/users/{userId}/posts/{postId}/analytics/{analyticsId}",
        "definition": {
          "schema": {
            "$ref": "#/backend/entities/PostAnalytics"
          },
          "description": "Engagement data for a specific post."
        }
      }
    ]
  }
}
